{
	"name": "@bopstack/pi-codegraph",
	"version": "0.1.0",
	"private": true,
	"description": "CodeGraph code understanding extension for pi",
	"keywords": [
		"pi-package"
	],
	"type": "module",
	"scripts": {
		"test": "vitest run",
		"test:watch": "vitest",
		"typecheck": "tsc -p tsconfig.json --noEmit"
	},
	"devDependencies": {
		"@earendil-works/pi-coding-agent": "^0.78.0",
		"typebox": "^1.1.38",
		"typescript": "^5.9.0",
		"vitest": "^4.1.7"
	},
	"peerDependencies": {
		"@earendil-works/pi-coding-agent": "*"
	},
	"main": "src/index.ts",
	"types": "src/index.ts",
	"exports": {
		".": {
			"default": "./src/index.ts",
			"import": "./src/index.ts"
		}
	},
	"pi": {
		"extensions": [
			"./src/index.ts"
		]
	},
	"omp": {
		"extensions": [
			"./src/index.ts"
		]
	},
	"dependencies": {
		"@earendil-works/pi-tui": "^0.78.1"
	}
}
